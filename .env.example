# Copy this to .env for local dev — never commit .env

# Required: UiPath bearer token (run `uip auth token` after `uip login`)
UIPATH_ACCESS_TOKEN=

# Tenant base URL
UIPATH_BASE_URL=https://staging.uipath.com/hackathon26_332/DefaultTenant

# Numeric OrganizationUnitId of the AgentHack team folder (for bucket ops)
UIPATH_FOLDER_ID=3054578

# Numeric OrganizationUnitId of the Maestro Case subfolder (for job start)
# Shared/UiPath AgentHack_2026/ReimbursementProcessMaestro  id=3154132
UIPATH_CASE_FOLDER_NUMERIC_ID=3154132

# Storage bucket numeric id ("Receipt" bucket)
UIPATH_BUCKET_ID=199727

# Release key UUID for the Maestro Case process
UIPATH_CASE_RELEASE_KEY=8602dfb7-4304-4768-b853-544f1ef7d972
